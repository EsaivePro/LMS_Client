{
    "title": "Exam Details",
    "fetchConfig": {
        "endpoint": "/form-service/get",
        "table": "exams",
        "joins": [
            "exam_schedules",
            "exam_sections"
        ],
        "subJoins": {
            "exam_sections": {
                "key": "section_id",
                "column": [
                    "title"
                ]
            }
        }
    },
    "sections": [
        {
            "key": "basic",
            "title": "Basic Details",
            "fields": [
                {
                    "name": "id",
                    "label": "ID",
                    "type": "number",
                    "readOnly": true,
                    "col": 6
                },
                {
                    "name": "title",
                    "label": "Title",
                    "type": "text",
                    "required": true,
                    "col": 6
                },
                {
                    "name": "display_name",
                    "label": "Display Name",
                    "type": "text",
                    "col": 6
                },
                {
                    "name": "description",
                    "label": "Description",
                    "type": "textarea",
                    "fullWidth": true
                }
            ]
        },
        {
            "key": "settings",
            "title": "Settings",
            "fields": [
                {
                    "name": "total_marks",
                    "label": "Total Marks",
                    "type": "number",
                    "required": true,
                    "default": 100,
                    "col": 6
                },
                {
                    "name": "passing_marks",
                    "label": "Passing Marks",
                    "type": "number",
                    "required": true,
                    "default": 40,
                    "col": 6
                },
                {
                    "name": "duration",
                    "label": "Duration (mins)",
                    "type": "number",
                    "required": true,
                    "default": 30,
                    "col": 6
                }
            ]
        },
        {
            "key": "exam_sections",
            "title": "Sections",
            "fields": [
                {
                    "name": "exam_sections",
                    "label": "Section Assignments",
                    "type": "record-picker",
                    "pickerConfig": {
                        "title": "Browse Sections",
                        "buttonLabel": "Browse & Add Sections",
                        "endpoint": "/common-service/search",
                        "tableName": "sections",
                        "mapRow": {
                            "section_id": "id",
                            "sections_title": "title",
                            "order_no": null
                        },
                        "displayColumns": [
                            {
                                "name": "id",
                                "label": "ID",
                                "minWidth": 70
                            },
                            {
                                "name": "title",
                                "label": "Section",
                                "minWidth": 340
                            },
                            {
                                "name": "display_name",
                                "label": "Display Name",
                                "minWidth": 200
                            },
                            {
                                "name": "is_active",
                                "label": "Status",
                                "minWidth": 120,
                                "filterable": true,
                                "filterOptions": [
                                    "true",
                                    "false"
                                ]
                            }
                        ]
                    },
                    "table": {
                        "columns": [
                            {
                                "name": "section_id",
                                "label": "ID",
                                "type": "number",
                                "minWidth": 70
                            },
                            {
                                "name": "sections_title",
                                "label": "Section",
                                "type": "text",
                                "minWidth": 500
                            },
                            {
                                "name": "order_no",
                                "label": "Order",
                                "type": "number",
                                "minWidth": 80
                            },
                            {
                                "name": "actions",
                                "label": "",
                                "type": "actions",
                                "minWidth": 50
                            }
                        ],
                        "allowDelete": true,
                        "draggable": true,
                        "minRows": 0
                    }
                }
            ]
        },
        {
            "key": "schedules",
            "title": "Schedules",
            "fields": [
                {
                    "name": "exam_schedules",
                    "label": "Exam Schedules",
                    "type": "table",
                    "table": {
                        "columns": [
                            {
                                "name": "start_time",
                                "label": "Start Time",
                                "type": "datetime",
                                "minWidth": 180
                            },
                            {
                                "name": "end_time",
                                "label": "End Time",
                                "type": "datetime",
                                "minWidth": 180
                            },
                            {
                                "name": "max_attempts",
                                "label": "Max Attempts",
                                "type": "number",
                                "default": 1,
                                "minWidth": 120
                            },
                            {
                                "name": "is_active",
                                "label": "Active",
                                "type": "checkbox",
                                "minWidth": 80
                            },
                            {
                                "name": "actions",
                                "label": "",
                                "type": "actions",
                                "minWidth": 80
                            }
                        ],
                        "addButton": {
                            "label": "Add Schedule",
                            "mode": "inline"
                        },
                        "layout": "cards",
                        "allowDelete": true,
                        "minRows": 0
                    }
                }
            ]
        },
        {
            "key": "options",
            "title": "Options",
            "fields": [
                {
                    "name": "shuffle_questions",
                    "label": "Shuffle Questions",
                    "type": "checkbox"
                },
                {
                    "name": "shuffle_options",
                    "label": "Shuffle Options",
                    "type": "checkbox"
                },
                {
                    "name": "is_active",
                    "label": "Active",
                    "type": "checkbox",
                    "default": true
                }
            ]
        }
    ]
}