{
    "title": "Module Category Details",
    "module": "module_category",
    "fetchConfig": {
        "endpoint": "/form-service/get",
        "table": "module_category",
        "joins": [
            "module_category_assign"
        ],
        "subJoins": {}
    },
    "sections": [
        {
            "key": "basic",
            "title": "Basic Details",
            "fields": [
                {
                    "name": "id",
                    "label": "ID",
                    "type": "number",
                    "readOnly": true
                },
                {
                    "name": "title",
                    "label": "Title",
                    "type": "text",
                    "required": true
                },
                {
                    "name": "description",
                    "label": "Description",
                    "type": "textarea",
                    "fullWidth": true
                },
                {
                    "name": "file_id",
                    "label": "Card Image",
                    "type": "fileupload",
                    "accept": "image/*",
                    "uploadPath": "images/module-category",
                    "buttonLabel": "Upload Image"
                },
                {
                    "name": "duration",
                    "label": "Duration",
                    "type": "number",
                    "default": 0
                }
            ]
        },
        {
            "key": "enrollment-process",
            "title": "Enrollment Process",
            "fields": [
                {
                    "name": "enrollment_type",
                    "label": "Enrollment Type",
                    "type": "select",
                    "required": true,
                    "options": [
                        {
                            "label": "Assigned",
                            "value": "assigned"
                        }
                    ],
                    "default": "assigned",
                    "conditionalFields": {
                        "scheduled": [
                            "scheduled_start_at",
                            "scheduled_end_at"
                        ],
                        "assigned": [
                            "numberofdays"
                        ]
                    }
                },
                {
                    "name": "enroll_mode",
                    "label": "Enroll Mode",
                    "type": "select",
                    "required": true,
                    "options": [
                        {
                            "label": "Day Wise",
                            "value": "daywise"
                        },
                        {
                            "label": "Completion Wise",
                            "value": "completionwise"
                        }
                    ],
                    "default": "daywise"
                },
                {
                    "name": "numberofdays",
                    "label": "Number of Days",
                    "type": "number",
                    "default": 0
                },
                {
                    "name": "scheduled_start_at",
                    "label": "Scheduled Start",
                    "type": "datetime"
                },
                {
                    "name": "scheduled_end_at",
                    "label": "Scheduled End",
                    "type": "datetime"
                }
            ]
        },
        {
            "key": "module-assignment",
            "title": "Module Assignment",
            "fields": [
                {
                    "name": "module_category_assign",
                    "label": "Module Assignments",
                    "type": "record-dailog",
                    "fullWidth": true,
                    "dialogConfig": {
                        "addButtonLabel": "Assign",
                        "createButtonLabel": "Add Record",
                        "updateButtonLabel": "Update Record",
                        "tableColumns": [
                            {
                                "field": "module_item_id",
                                "label": "Module ID",
                                "minWidth": 120
                            },
                            {
                                "field": "module_type",
                                "label": "Module Type",
                                "minWidth": 140
                            },
                            {
                                "field": "module_item_label",
                                "label": "Module Title",
                                "minWidth": 260
                            },
                            {
                                "field": "sortorder",
                                "label": "Sort Order",
                                "minWidth": 120
                            }
                        ],
                        "fields": [
                            {
                                "name": "module_type",
                                "label": "Module Type",
                                "type": "select",
                                "default": "course",
                                "conditionalFields": {
                                    "course": [
                                        "module_item_id"
                                    ],
                                    "exam": [
                                        "module_item_id",
                                        "attempt_limit",
                                        "time_limit_minutes"
                                    ]
                                },
                                "options": [
                                    {
                                        "label": "Course",
                                        "value": "course"
                                    },
                                    {
                                        "label": "Exam",
                                        "value": "exam"
                                    }
                                ]
                            },
                            {
                                "name": "module_item_id",
                                "label": "Module Item",
                                "type": "autocomplete",
                                "required": true,
                                "sourceColumns": [
                                    "id",
                                    "title"
                                ],
                                "sourceBy": "module_type",
                                "sourceMap": {
                                    "course": "courses",
                                    "exam": "exams"
                                },
                                "storeLabelAs": "module_item_label"
                            },
                            {
                                "name": "day",
                                "label": "Day",
                                "type": "number",
                                "default": 0
                            },
                            {
                                "name": "sortorder",
                                "label": "Sort Order",
                                "type": "number",
                                "default": 0
                            },
                            {
                                "name": "attempt_limit",
                                "label": "Attempt Limit",
                                "type": "number",
                                "default": null
                            },
                            {
                                "name": "time_limit_minutes",
                                "label": "Time Limit Minutes",
                                "type": "number",
                                "default": null
                            }
                        ]
                    }
                }
            ]
        }
    ]
}