{
    "title": "Question Section Details",
    "tablename": "questions_section",
    "fetchConfig": {
        "endpoint": "/form-service/get",
        "table": "questions_section",
        "joins": [],
        "subJoins": {
            "questions_section": {
                "key": "question_id",
                "column": [
                    "title"
                ]
            }
        }
    },
    "sections": [
        {
            "key": "basic",
            "title": "Basic Details",
            "fields": [
                {
                    "name": "id",
                    "label": "ID",
                    "type": "number",
                    "readOnly": true
                },
                {
                    "name": "title",
                    "label": "Title",
                    "type": "text",
                    "required": true
                },
                {
                    "name": "display_name",
                    "label": "Display Name",
                    "type": "text"
                },
                {
                    "name": "description",
                    "label": "Description",
                    "type": "textarea",
                    "fullWidth": true
                }
            ]
        },
        {
            "key": "config",
            "title": "Configuration",
            "fields": [
                {
                    "name": "config_items",
                    "label": "Question Assignments",
                    "type": "record-picker",
                    "pickerConfig": {
                        "title": "Browse Questions",
                        "buttonLabel": "Browse & Add Questions",
                        "endpoint": "/common-service/search",
                        "tableName": "questions_master",
                        "mapRow": {
                            "question_id": "id",
                            "title": "title",
                            "question_type": "question_type",
                            "difficulty_level": "difficulty_level",
                            "order_no": null
                        },
                        "displayColumns": [
                            {
                                "name": "id",
                                "label": "ID",
                                "minWidth": 70
                            },
                            {
                                "name": "title",
                                "label": "Question",
                                "minWidth": 340
                            },
                            {
                                "name": "question_type",
                                "label": "Type",
                                "minWidth": 160,
                                "filterable": true,
                                "filterOptions": [
                                    "mcq",
                                    "multiple_select",
                                    "true_false"
                                ]
                            },
                            {
                                "name": "difficulty_level",
                                "label": "Difficulty",
                                "minWidth": 120,
                                "filterable": true,
                                "filterOptions": [
                                    "easy",
                                    "medium",
                                    "hard"
                                ]
                            }
                        ]
                    },
                    "table": {
                        "columns": [
                            {
                                "name": "question_id",
                                "label": "ID",
                                "type": "number",
                                "minWidth": 70
                            },
                            {
                                "name": "title",
                                "label": "Question",
                                "type": "text",
                                "minWidth": 300
                            },
                            {
                                "name": "order_no",
                                "label": "Order",
                                "type": "number",
                                "minWidth": 80
                            },
                            {
                                "name": "actions",
                                "label": "",
                                "type": "actions",
                                "minWidth": 50
                            }
                        ],
                        "allowDelete": true,
                        "minRows": 0
                    }
                }
            ]
        },
        {
            "key": "status",
            "title": "Status",
            "fields": [
                {
                    "name": "is_active",
                    "label": "Active",
                    "type": "checkbox",
                    "default": true
                }
            ]
        }
    ]
}