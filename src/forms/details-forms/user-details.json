{
    "title": "User Details",
    "fetchConfig": {
        "endpoint": "/form-service/get",
        "table": "users",
        "joins": [],
        "subJoins": {}
    },
    "sections": [
        {
            "key": "basic",
            "title": "Basic Details",
            "fields": [
                {
                    "name": "id",
                    "label": "ID",
                    "type": "number",
                    "readOnly": true,
                    "minWidth": 120
                },
                {
                    "name": "username",
                    "label": "Username",
                    "type": "text",
                    "required": true,
                    "minWidth": 320
                },
                {
                    "name": "email",
                    "label": "Email",
                    "type": "text",
                    "required": true,
                    "minWidth": 320
                },
                {
                    "name": "phonenumber",
                    "label": "Phone Number",
                    "type": "text",
                    "minWidth": 200
                },
                {
                    "name": "first_name",
                    "label": "First Name",
                    "type": "text",
                    "minWidth": 240
                },
                {
                    "name": "last_name",
                    "label": "Last Name",
                    "type": "text",
                    "minWidth": 240
                },
                {
                    "name": "status",
                    "label": "Status",
                    "type": "select",
                    "options": [
                        { "label": "Active", "value": "active" },
                        { "label": "Inactive", "value": "inactive" },
                        { "label": "Suspended", "value": "suspended" }
                    ],
                    "minWidth": 200
                },
                {
                    "name": "location",
                    "label": "Location",
                    "type": "text",
                    "minWidth": 320
                },
                {
                    "name": "timezone",
                    "label": "Timezone",
                    "type": "text",
                    "minWidth": 200
                },
                {
                    "name": "language",
                    "label": "Language",
                    "type": "text",
                    "minWidth": 140
                }
            ]
        },
        {
            "key": "account",
            "title": "Account Info",
            "fields": [
                {
                    "name": "email_verified",
                    "label": "Email Verified",
                    "type": "boolean",
                    "readOnly": true,
                    "minWidth": 160
                },
                {
                    "name": "last_login_at",
                    "label": "Last Login",
                    "type": "datetime",
                    "readOnly": true,
                    "minWidth": 200
                },
                {
                    "name": "login_attempts",
                    "label": "Login Attempts",
                    "type": "number",
                    "readOnly": true,
                    "minWidth": 160
                }
            ]
        }
    ]
}
