{
    "title": "Group Details",
    "fetchConfig": {
        "endpoint": "/form-service/get",
        "table": "groups",
        "joins": [
            "groups_category"
        ],
        "subJoins": {
            "groups_category": {
                "key": "module_category_id",
                "column": [
                    "title"
                ]
            }
        }
    },
    "sections": [
        {
            "key": "basic",
            "title": "Basic Details",
            "fields": [
                {
                    "name": "id",
                    "label": "ID",
                    "type": "number",
                    "readOnly": true
                },
                {
                    "name": "name",
                    "label": "Name",
                    "type": "text",
                    "required": true,
                    "minWidth": 320
                },
                {
                    "name": "description",
                    "label": "Description",
                    "type": "textarea",
                    "minWidth": 640
                }
            ]
        },
        {
            "key": "groups_category",
            "title": "Category Assignment",
            "fields": [
                {
                    "name": "groups_category",
                    "label": "Course Categories",
                    "type": "record-assigned",
                    "assignedConfig": {
                        "endpoint": "/form-service/advanced-search",
                        "table": "module_category",
                        "identityKey": "id",
                        "columns": [
                            "id",
                            "title",
                            "created_at"
                        ],
                        "orderby": [
                            {
                                "table": "groups_category",
                                "where": {
                                    "group_id": "{recordId}"
                                },
                                "on": "module_category_id"
                            }
                        ],
                        "sortby": "created_at",
                        "order": "desc",
                        "mapData": {
                            "id": "{groups_category_id}",
                            "module_category_id": "{id}",
                            "is_deleted": "{is_deleted}",
                            "assigned": true
                        },
                        "displayColumns": [
                            {
                                "field": "id",
                                "headerName": "ID",
                                "type": "number",
                                "minWidth": 80
                            },
                            {
                                "field": "title",
                                "headerName": "Category Title",
                                "type": "text",
                                "minWidth": 380
                            }
                        ]
                    }
                }
            ]
        },
        {
            "key": "user_groups_assign",
            "title": "User Assignments",
            "fields": [
                {
                    "name": "user_groups_assign",
                    "label": "Assigned Users",
                    "type": "record-assigned",
                    "assignedConfig": {
                        "endpoint": "/form-service/advanced-search",
                        "table": "users",
                        "identityKey": "id",
                        "columns": [
                            "id",
                            "email",
                            "first_name",
                            "last_name",
                            "status",
                            "created_at"
                        ],
                        "orderby": [
                            {
                                "table": "user_groups_assign",
                                "where": {
                                    "group_id": "{recordId}"
                                },
                                "on": "user_id"
                            }
                        ],
                        "sortby": "created_at",
                        "order": "desc",
                        "mapData": {
                            "id": "{user_groups_assign_id}",
                            "user_id": "{id}",
                            "is_deleted": "{is_deleted}",
                            "assigned": true
                        },
                        "displayColumns": [
                            {
                                "field": "id",
                                "headerName": "ID",
                                "type": "number",
                                "minWidth": 80
                            },
                            {
                                "field": "email",
                                "headerName": "Email",
                                "type": "text",
                                "minWidth": 380
                            },
                            {
                                "field": "first_name",
                                "headerName": "First Name",
                                "type": "text",
                                "minWidth": 140
                            },
                            {
                                "field": "last_name",
                                "headerName": "Last Name",
                                "type": "text",
                                "minWidth": 140
                            },
                            {
                                "field": "status",
                                "headerName": "Status",
                                "type": "text",
                                "minWidth": 110
                            }
                        ]
                    }
                }
            ]
        }
    ]
}