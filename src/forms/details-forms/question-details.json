{
    "title": "Question Details",
    "tablename": "questions_master",
    "fetchConfig": {
        "endpoint": "/form-service/get",
        "table": "questions_master",
        "joins": [
            "question_options"
        ]
    },
    "sections": [
        {
            "key": "basic",
            "title": "Basic Details",
            "fields": [
                {
                    "name": "id",
                    "label": "ID",
                    "type": "number",
                    "readOnly": true
                },
                {
                    "name": "title",
                    "label": "Question Title",
                    "type": "text",
                    "required": true,
                    "fullWidth": true
                },
                {
                    "name": "description",
                    "label": "Description / Explanation",
                    "type": "textarea",
                    "fullWidth": true
                },
                {
                    "name": "question_type",
                    "label": "Question Type",
                    "type": "select",
                    "required": true,
                    "options": [
                        {
                            "value": "mcq",
                            "label": "Multiple Choice (MCQ)"
                        },
                        {
                            "value": "multiple_select",
                            "label": "Multiple Select"
                        },
                        {
                            "value": "true_false",
                            "label": "True / False"
                        }
                    ]
                },
                {
                    "name": "difficulty_level",
                    "label": "Difficulty Level",
                    "type": "select",
                    "options": [
                        {
                            "value": "easy",
                            "label": "Easy"
                        },
                        {
                            "value": "medium",
                            "label": "Medium"
                        },
                        {
                            "value": "hard",
                            "label": "Hard"
                        }
                    ]
                },
                {
                    "name": "topic_id",
                    "label": "Topic",
                    "type": "select",
                    "optionsSource": "qb_topics"
                }
            ]
        },
        {
            "key": "scoring",
            "title": "Scoring",
            "fields": [
                {
                    "name": "marks",
                    "label": "Marks",
                    "type": "number",
                    "required": true,
                    "default": 1
                },
                {
                    "name": "negative_marks",
                    "label": "Negative Marks",
                    "type": "number",
                    "default": 0
                }
            ]
        },
        {
            "key": "answer_options",
            "title": "Answer Options",
            "fields": [
                {
                    "name": "question_options",
                    "label": "Answer Options",
                    "type": "table",
                    "table": {
                        "columns": [
                            {
                                "name": "option_text",
                                "label": "Option Text",
                                "type": "text",
                                "minWidth": 400,
                                "required": true
                            },
                            {
                                "name": "is_correct",
                                "label": "Correct",
                                "type": "checkbox",
                                "minWidth": 80
                            },
                            {
                                "name": "actions",
                                "label": "",
                                "type": "actions",
                                "minWidth": 60
                            }
                        ],
                        "addButton": {
                            "label": "Add Option",
                            "mode": "inline"
                        },
                        "layout": "cards",
                        "allowDelete": true,
                        "minRows": 0
                    }
                }
            ]
        },
        {
            "key": "status",
            "title": "Status",
            "fields": [
                {
                    "name": "is_active",
                    "label": "Active",
                    "type": "checkbox",
                    "default": true
                }
            ]
        }
    ]
}