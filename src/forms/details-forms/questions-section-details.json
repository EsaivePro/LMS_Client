{
    "title": "Section Details",
    "fetchConfig": {
        "endpoint": "/form-service/get",
        "table": "sections",
        "joins": [
            "questions_section"
        ]
    },
    "sections": [
        {
            "key": "basic",
            "title": "General Information",
            "fields": [
                {
                    "name": "id",
                    "label": "ID",
                    "type": "number",
                    "readOnly": true,
                    "col": 6
                },
                {
                    "name": "title",
                    "label": "Title",
                    "type": "text",
                    "required": true,
                    "col": 6
                },
                {
                    "name": "display_name",
                    "label": "Display Name",
                    "type": "text",
                    "col": 6
                },
                {
                    "name": "description",
                    "label": "Description",
                    "type": "textarea",
                    "fullWidth": true
                }
            ]
        },
        {
            "key": "state",
            "title": "Record State",
            "fields": [
                {
                    "name": "modules",
                    "label": "Module Type",
                    "type": "text",
                    "default": "Questions",
                    "readOnly": true,
                    "required": true
                },
                {
                    "name": "is_active",
                    "label": "Active",
                    "type": "checkbox",
                    "default": true
                }
            ]
        },
        {
            "key": "questions_section",
            "title": "Questions Allocation",
            "fields": [
                {
                    "name": "questions_section",
                    "label": "questions",
                    "type": "record-assigned",
                    "fullWidth": true,
                    "assignedConfig": {
                        "singularLabel": "questions",
                        "maxRecords": 10,
                        "endpoint": "/form-service/advanced-search",
                        "table": "questions_master",
                        "identityKey": "id",
                        "orderby": [
                            {
                                "table": "questions_section",
                                "columns": [
                                    "order_no"
                                ],
                                "where": {
                                    "section_id": "{recordId}"
                                },
                                "on": "question_id"
                            }
                        ],
                        "sortby": "created_at",
                        "order": "desc",
                        "mapData": {
                            "id": "{questions_section_id}",
                            "question_id": "{id}",
                            "is_deleted": "{is_deleted}",
                            "order_no": 1,
                            "assigned": true
                        },
                        "dragDrop": true,
                        "dragOrderBy": "questions_section_order_no",
                        "navigateTo": "/questions/manage/{id}",
                        "displayColumns": [
                            {
                                "field": "id",
                                "headerName": "ID",
                                "type": "number",
                                "minWidth": 80
                            },
                            {
                                "field": "title",
                                "headerName": "Title",
                                "type": "text",
                                "minWidth": 200
                            },
                            {
                                "field": "question_type",
                                "headerName": "Question Type",
                                "type": "text",
                                "minWidth": 160
                            },
                            {
                                "field": "difficulty_level",
                                "headerName": "Difficulty Level",
                                "type": "text",
                                "minWidth": 140
                            },
                            {
                                "field": "marks",
                                "headerName": "Marks",
                                "type": "number",
                                "minWidth": 120
                            },
                            {
                                "field": "description",
                                "headerName": "Description",
                                "type": "text",
                                "minWidth": 200
                            }
                        ]
                    }
                }
            ]
        }
    ]
}