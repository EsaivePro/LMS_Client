{
    "title": "Exam Section Details",
    "tablename": "exams_section",
    "fetchConfig": {
        "endpoint": "/form-service/get",
        "table": "exams_section",
        "joins": []
    },
    "sections": [
        {
            "key": "basic",
            "title": "Basic Details",
            "fields": [
                {
                    "name": "id",
                    "label": "ID",
                    "type": "number",
                    "readOnly": true
                },
                {
                    "name": "title",
                    "label": "Title",
                    "type": "text",
                    "required": true
                },
                {
                    "name": "display_name",
                    "label": "Display Name",
                    "type": "text"
                },
                {
                    "name": "description",
                    "label": "Description",
                    "type": "textarea",
                    "fullWidth": true
                }
            ]
        },
        {
            "key": "config",
            "title": "Configuration",
            "fields": [
                {
                    "name": "exam_id",
                    "label": "Exam",
                    "type": "select",
                    "required": true,
                    "optionsSource": "exams"
                },
                {
                    "name": "questions_section_id",
                    "label": "Question Section",
                    "type": "number"
                },
                {
                    "name": "order_no",
                    "label": "Order No",
                    "type": "number",
                    "default": 1
                }
            ]
        },
        {
            "key": "status",
            "title": "Status",
            "fields": [
                {
                    "name": "is_active",
                    "label": "Active",
                    "type": "checkbox",
                    "default": true
                }
            ]
        }
    ]
}
