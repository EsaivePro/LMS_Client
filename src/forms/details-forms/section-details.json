{
    "title": "Section Details",
    "fetchConfig": {
        "endpoint": "/form-service/get",
        "table": "sections",
        "joins": [
            "questions_section"
        ],
        "subJoins": {
            "questions_section": {
                "key": "question_id",
                "column": [
                    "title"
                ]
            }
        }
    },
    "sections": [
        {
            "key": "basic",
            "title": "Basic Details",
            "fields": [
                {
                    "name": "id",
                    "label": "ID",
                    "type": "number",
                    "readOnly": true,
                    "col": 6
                },
                {
                    "name": "title",
                    "label": "Title",
                    "type": "text",
                    "required": true,
                    "col": 6
                },
                {
                    "name": "display_name",
                    "label": "Display Name",
                    "type": "text",
                    "col": 6
                },
                {
                    "name": "description",
                    "label": "Description",
                    "type": "textarea",
                    "fullWidth": true
                }
            ]
        },
        {
            "key": "questions_section",
            "title": "Configuration",
            "fields": [
                {
                    "name": "questions_section",
                    "label": "Question Assignments",
                    "type": "record-picker",
                    "pickerConfig": {
                        "title": "Browse Questions",
                        "buttonLabel": "Browse & Add Questions",
                        "endpoint": "/common-service/search",
                        "tableName": "questions_master",
                        "mapRow": {
                            "question_id": "id",
                            "questions_master_title": "title",
                            "order_no": null
                        },
                        "displayColumns": [
                            {
                                "name": "id",
                                "label": "ID",
                                "minWidth": 70
                            },
                            {
                                "name": "title",
                                "label": "Question",
                                "minWidth": 340
                            },
                            {
                                "name": "question_type",
                                "label": "Type",
                                "minWidth": 160,
                                "filterable": true,
                                "filterOptions": [
                                    "mcq",
                                    "multiple_select",
                                    "true_false"
                                ]
                            },
                            {
                                "name": "difficulty_level",
                                "label": "Difficulty",
                                "minWidth": 120,
                                "filterable": true,
                                "filterOptions": [
                                    "easy",
                                    "medium",
                                    "hard"
                                ]
                            }
                        ]
                    },
                    "table": {
                        "columns": [
                            {
                                "name": "question_id",
                                "label": "ID",
                                "type": "number",
                                "minWidth": 70
                            },
                            {
                                "name": "questions_master_title",
                                "label": "Question",
                                "type": "text",
                                "minWidth": 600
                            },
                            {
                                "name": "order_no",
                                "label": "Order",
                                "type": "number",
                                "minWidth": 80
                            },
                            {
                                "name": "actions",
                                "label": "",
                                "type": "actions",
                                "minWidth": 50
                            }
                        ],
                        "allowDelete": true,
                        "draggable": true,
                        "minRows": 0
                    }
                }
            ]
        },
        {
            "key": "options",
            "title": "Options",
            "fields": [
                {
                    "name": "is_active",
                    "label": "Active",
                    "type": "checkbox",
                    "default": true
                }
            ]
        }
    ]
}