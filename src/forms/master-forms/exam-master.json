{
    "baseRoute": "/exams/manage",
    "tableName": "exams",
    "endpoint": "/common-service/search",
    "readFrom": "response.data",
    "serverSide": true,
    "tableKey": "exams-table",
    "rowDoubleClick": "/exams/manage/{id}",
    "manageRoute": false,
    "moreColumn": [
        "Edit",
        "Delete"
    ],
    "header": {
        "title": "Exams",
        "showCount": true,
        "buttons": [
            {
                "key": "create",
                "label": "New Exam",
                "variant": "contained"
            }
        ]
    },
    "fields": [
        {
            "key": "id",
            "label": "ID",
            "type": "number",
            "maxWidth": 100
        },
        {
            "key": "title",
            "label": "Title",
            "type": "string",
            "minWidth": 240,
            "filterable": true,
            "linkTemplate": "{id}"
        },
        {
            "key": "description",
            "label": "Description",
            "type": "string",
            "minWidth": 300
        },
        {
            "key": "total_marks",
            "label": "Total Marks",
            "type": "number",
            "minWidth": 120
        },
        {
            "key": "duration_minutes",
            "label": "Duration (mins)",
            "type": "number",
            "minWidth": 140
        },
        {
            "key": "is_active",
            "label": "Status",
            "type": "boolean",
            "minWidth": 120,
            "valueOptions": [
                true,
                false
            ],
            "renderValues": {
                "true": "Active",
                "false": "Inactive"
            }
        },
        {
            "key": "created_at",
            "label": "Created At",
            "type": "datetime",
            "minWidth": 180
        }
    ]
}