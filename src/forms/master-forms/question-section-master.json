{
    "baseRoute": "/question-sections/manage",
    "tableName": "questions_section",
    "endpoint": "/common-service/search",
    "readFrom": "response.data",
    "serverSide": true,
    "tableKey": "question-sections-table",
    "header": {
        "title": "Question Sections",
        "showCount": true,
        "buttons": [
            {
                "key": "create",
                "label": "New Section",
                "variant": "contained"
            }
        ]
    },
    "fields": [
        {
            "name": "id",
            "label": "ID",
            "type": "number",
            "maxWidth": 80
        },
        {
            "name": "title",
            "label": "Title",
            "type": "string",
            "minWidth": 240,
            "filterable": true,
            "linkTemplate": "{id}"
        },
        {
            "name": "display_name",
            "label": "Display Name",
            "type": "string",
            "minWidth": 200
        },
        {
            "name": "order_no",
            "label": "Order",
            "type": "number",
            "minWidth": 80
        },
        {
            "name": "is_active",
            "label": "Status",
            "type": "boolean",
            "minWidth": 100,
            "valueOptions": [true, false],
            "renderValues": {
                "true": "Active",
                "false": "Inactive"
            }
        },
        {
            "name": "created_at",
            "label": "Created At",
            "type": "string",
            "minWidth": 160
        },
        {
            "name": "actions",
            "label": "Actions",
            "type": "actions",
            "maxWidth": 120,
            "minWidth": 150,
            "pinned": "right",
            "sortable": false
        }
    ]
}
