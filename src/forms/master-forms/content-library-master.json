{
    "baseRoute": "/content-library/manage",
    "tableName": "content_library",
    "endpoint": "/common-service/search",
    "readFrom": "response.data",
    "serverSide": true,
    "rowDoubleClick": "/content-library/manage/{id}",
    "manageRoute": false,
    "moreColumn": [
        "Edit",
        "Delete"
    ],
