        },
        {
            "key": "content_type",
            "label": "Content Type",
            "type": "string",
            "minWidth": 140
        },
        {
            "key": "visibility",
            "label": "Visibility",
            "type": "string",
            "minWidth": 120
        },
        {
            "key": "duration",
            "label": "Duration",
            "type": "number",
            "minWidth": 120
        },
        {
            "key": "tags",
            "label": "Tags",
            "type": "string",
            "minWidth": 220
        },
        {
            "key": "created_at",
            "label": "Created At",
            "type": "datetime",
            "minWidth": 180
        }
    ]
