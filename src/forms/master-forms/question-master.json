{
    "baseRoute": "/questions/manage",
    "tableName": "questions_master",
    "endpoint": "/common-service/search",
    "readFrom": "response.data",
    "serverSide": true,
    "rowDoubleClick": "/questions/manage/{id}",
    "manageRoute": false,
    "moreColumn": [
        "Edit",
        "Delete"
    ],
    "tableKey": "questions-table",
    "header": {
        "title": "Questions Bank",
        "showCount": true,
        "buttons": [
            {
                "key": "create",
                "label": "New Question",
                "variant": "contained"
            }
        ]
    },
    "fields": [
        {
            "key": "id",
            "label": "ID",
            "type": "number",
            "maxWidth": 80
        },
        {
            "key": "title",
            "label": "Question",
            "type": "string",
            "minWidth": 600,
            "filterable": true,
            "linkTemplate": "{id}"
        },
        {
            "key": "question_type",
            "label": "Type",
            "type": "string",
            "minWidth": 160,
            "filterable": true,
            "renderValues": {
                "mcq": "MCQ",
                "multiple_select": "Multiple Select",
                "true_false": "True / False"
            }
        },
        {
            "key": "difficulty_level",
            "label": "Difficulty",
            "type": "string",
            "minWidth": 120,
            "filterable": true,
            "renderValues": {
                "easy": "Easy",
                "medium": "Medium",
                "hard": "Hard"
            }
        },
        {
            "key": "topic_id",
            "label": "Topic",
            "type": "number",
            "minWidth": 160
        },
        {
            "key": "marks",
            "label": "Marks",
            "type": "number",
            "minWidth": 80
        },
        {
            "key": "negative_marks",
            "label": "Neg. Marks",
            "type": "number",
            "minWidth": 100
        },
        {
            "key": "is_active",
            "label": "Status",
            "type": "boolean",
            "minWidth": 100,
            "valueOptions": [
                true,
                false
            ],
            "renderValues": {
                "true": "Active",
                "false": "Inactive"
            }
        },
        {
            "key": "created_at",
            "label": "Created At",
            "type": "datetime",
            "minWidth": 160
        }
    ]
}